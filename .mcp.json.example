{
  "mcpServers": {
    "gcloud": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"],
      "env": {
        "CLOUDSDK_CORE_PROJECT": "your-gcp-project-id",
        "CLOUDSDK_COMPUTE_REGION": "us-central1",
        "CLOUDSDK_COMPUTE_ZONE": "us-central1-a"
      }
    },
    "kubernetes": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server@latest", "--read-only"],
      "env": {}
    },
    "clickhouse-test": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.10",
        "mcp-clickhouse"
      ],
      "env": {
        "CLICKHOUSE_HOST": "clickhouse.example-test.com",
        "CLICKHOUSE_PORT": "80",
        "CLICKHOUSE_USER": "readonly",
        "CLICKHOUSE_PASSWORD": "your-test-password-here",
        "CLICKHOUSE_SECURE": "false",
        "CLICKHOUSE_VERIFY": "false",
        "CLICKHOUSE_CONNECT_TIMEOUT": "30",
        "CLICKHOUSE_SEND_RECEIVE_TIMEOUT": "30"
      }
    },
    "clickhouse-prod": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.10",
        "mcp-clickhouse"
      ],
      "env": {
        "CLICKHOUSE_HOST": "clickhouse.example.com",
        "CLICKHOUSE_PORT": "80",
        "CLICKHOUSE_USER": "readonly",
        "CLICKHOUSE_PASSWORD": "your-prod-password-here",
        "CLICKHOUSE_SECURE": "false",
        "CLICKHOUSE_VERIFY": "false",
        "CLICKHOUSE_CONNECT_TIMEOUT": "30",
        "CLICKHOUSE_SEND_RECEIVE_TIMEOUT": "30"
      }
    }
  }
}
